# Convert a SPIR-V .spv binary into a C header that exposes a fixed-size
# uint32_t[] named ${SYMBOL}. Invoked from add_custom_command in CMakeLists.
file(READ "${SPV_FILE}" SPV_HEX HEX)
string(LENGTH "${SPV_HEX}" HEX_LEN)
math(EXPR WORD_COUNT "${HEX_LEN} / 8")

set(BODY "/* Auto-generated by spv_to_header.cmake. Do not edit. */\n")
string(APPEND BODY "#pragma once\n")
string(APPEND BODY "#include <stdint.h>\n")
string(APPEND BODY "static const uint32_t ${SYMBOL}[${WORD_COUNT}] = {\n   ")

set(I 0)
set(LINE_COL 0)
while(I LESS HEX_LEN)
    math(EXPR I2 "${I} + 2")
    math(EXPR I3 "${I} + 4")
    math(EXPR I4 "${I} + 6")
    string(SUBSTRING "${SPV_HEX}" ${I}  2 B0)
    string(SUBSTRING "${SPV_HEX}" ${I2} 2 B1)
    string(SUBSTRING "${SPV_HEX}" ${I3} 2 B2)
    string(SUBSTRING "${SPV_HEX}" ${I4} 2 B3)
    string(APPEND BODY " 0x${B3}${B2}${B1}${B0},")
    math(EXPR LINE_COL "${LINE_COL} + 1")
    if(LINE_COL EQUAL 8)
        string(APPEND BODY "\n   ")
        set(LINE_COL 0)
    endif()
    math(EXPR I "${I} + 8")
endwhile()
string(APPEND BODY "\n};\n")

file(WRITE "${HEADER}" "${BODY}")
